{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./src/*"],
			"@react-navigation/native": ["./node_modules/@react-navigation/native/lib/typescript/src/index.d.ts"],
			"@rn-primitives/*": ["./node_modules/@rn-primitives/*/dist/index.d.ts"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts"
	]
}
